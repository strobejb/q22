<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE language>
<language
    name="Q22 Struct"
    version="3"
    kateversion="5.79"
    section="Sources"
    extensions="*.struct"
    mimetype="text/x-q22-struct"
    priority="20"
    author="q22"
    license="MIT">

<highlighting>
<list name="keywords">
    <item>const</item>
    <item>default</item>
    <item>display</item>
    <item>enum</item>
    <item>ignore</item>
    <item>include</item>
    <item>sizeof</item>
    <item>string</item>
    <item>struct</item>
    <item>style</item>
    <item>tagset</item>
    <item>typedef</item>
    <item>union</item>
</list>

<list name="typeKeywords">
    <item>byte</item>
    <item>word</item>
    <item>dword</item>
    <item>qword</item>
    <item>char</item>
    <item>wchar_t</item>
    <item>float</item>
    <item>double</item>
    <item>signed</item>
    <item>unsigned</item>
    <item>short</item>
    <item>long</item>
    <item>int</item>
</list>

<list name="tagKeywords">
    <item>align</item>
    <item>assoc</item>
    <item>bitflag</item>
    <item>case</item>
    <item>description</item>
    <item>display</item>
    <item>dynamic_container</item>
    <item>dynamic_struct</item>
    <item>endian</item>
    <item>entrypoint</item>
    <item>enum</item>
    <item>export</item>
    <item>length_is</item>
    <item>name</item>
    <item>offset</item>
    <item>offset_map</item>
    <item>optional</item>
    <item>size_is</item>
    <item>switch_is</item>
    <item>tags</item>
    <item>view</item>
</list>

<contexts>
    <context name="Normal" attribute="Normal Text" lineEndContext="#stay">
        <Detect2Chars char="/" char1="/" attribute="Comment" context="Line Comment"/>
        <Detect2Chars char="/" char1="*" attribute="Comment" context="Block Comment"/>
        <DetectChar char="&quot;" attribute="String" context="String"/>
        <DetectChar char="'" attribute="String" context="Char"/>
        <DetectChar char="[" attribute="Tag Bracket" context="Tag Block"/>
        <keyword String="typeKeywords" attribute="Type Keyword"/>
        <keyword String="keywords" attribute="Keyword"/>
        <Float attribute="Float"/>
        <Int attribute="Decimal"/>
        <AnyChar String="{}" attribute="Brace"/>
    </context>

    <context name="Line Comment" attribute="Comment" lineEndContext="#pop"/>

    <context name="Block Comment" attribute="Comment" lineEndContext="#stay">
        <Detect2Chars char="*" char1="/" attribute="Comment" context="#pop"/>
    </context>

    <context name="String" attribute="String" lineEndContext="#pop">
        <HlCStringChar attribute="Char"/>
        <DetectChar char="&quot;" attribute="String" context="#pop"/>
    </context>

    <context name="Char" attribute="String" lineEndContext="#pop">
        <HlCStringChar attribute="Char"/>
        <DetectChar char="'" attribute="String" context="#pop"/>
    </context>

    <context name="Tag Block" attribute="Tag Identifier" lineEndContext="#stay">
        <Detect2Chars char="/" char1="/" attribute="Comment" context="Line Comment"/>
        <Detect2Chars char="/" char1="*" attribute="Comment" context="Block Comment"/>
        <DetectChar char="&quot;" attribute="String" context="String"/>
        <DetectChar char="'" attribute="String" context="Char"/>
        <DetectChar char="[" attribute="Tag Bracket" context="Tag Block"/>
        <DetectChar char="]" attribute="Tag Bracket" context="#pop"/>
        <keyword String="tagKeywords" attribute="Tag Keyword"/>
        <keyword String="typeKeywords" attribute="Tag Keyword"/>
        <Float attribute="Float"/>
        <Int attribute="Decimal"/>
        <AnyChar String="(),.+-*/%&amp;|!~?:&lt;&gt;={}" attribute="Tag Punctuation"/>
    </context>
</contexts>

<itemDatas>
    <itemData name="Normal Text" defStyleNum="dsNormal"/>
    <itemData name="Keyword" defStyleNum="dsKeyword" color="#CF2338"/>
    <itemData name="Type Keyword" defStyleNum="dsDataType" color="#0651AE"/>
    <itemData name="Tag Keyword" defStyleNum="dsKeyword" color="#008952"/>
    <itemData name="Tag Identifier" defStyleNum="dsNormal" color="#74911C"/>
    <itemData name="Tag Punctuation" defStyleNum="dsOperator" color="#008952"/>
    <itemData name="Tag Bracket" defStyleNum="dsOperator" color="#008952" bold="1"/>
    <itemData name="Brace" defStyleNum="dsOperator"/>
    <itemData name="String" defStyleNum="dsString" color="#6D48C3"/>
    <itemData name="Char" defStyleNum="dsChar" color="#6D48C3"/>
    <itemData name="Comment" defStyleNum="dsComment"/>
    <itemData name="Decimal" defStyleNum="dsDecVal"/>
    <itemData name="Float" defStyleNum="dsFloat"/>
</itemDatas>
</highlighting>

<general>
    <keywords casesensitive="1"/>
</general>

</language>
